# Copy to .env.live and fill in real values.
# Used by: RUN_LIVE_TESTS=1 pytest tests/live/ -v

# Logto
LOGTO_ENDPOINT=https://fo9pu9.logto.app
LOGTO_API_RESOURCE=https://api.voiceforge.app

# MongoDB (use a TEST database, not production)
MONGODB_URI=mongodb+srv://...
MONGO_DB_NAME=mcp_core_test

# Stripe (test mode keys only)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_METER_EVENT_NAME=test_tool_calls

# Per-user token for auth tests
# Get from browser: DevTools -> Application -> Local Storage -> logto refresh token
TEST_USER_CLIENT_ID=
TEST_USER_REFRESH_TOKEN=
